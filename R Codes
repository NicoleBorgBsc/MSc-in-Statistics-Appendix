library(forecast)
#fitting Holt-Winters as a baseline model
spricesSP50train
# Test set: remaining observations
spricesSP50test
# Number of stocks
n_stocks <- ncol(spricesSP50train)

# Forecast horizon
h <- nrow(spricesSP50test)

# Store MSE for each stock
mse_list <- numeric(n_stocks)

for (i in 1:n_stocks) {
  # Convert stock series to time series
  ts_train <- ts(spricesSP50train[, i], frequency = 1)  # daily data
  
  # Fit Holt's linear method (level + trend, no seasonality)
  holt_model <- holt(ts_train, h = h)
  
  # Forecast
  forecast_values <- holt_model$mean
  
  # Compute MSE for this stock
  mse_list[i] <- mean((spricesSP50test[, i] - forecast_values)^2)
}


# Overall MSEP across all stocks
overall_msep <- mean(mse_list)
overall_msep

