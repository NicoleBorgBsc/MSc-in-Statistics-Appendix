library(stats)
# Function to adjust seasonality
adjust_seasonality <- function(data, frequency, seasonality_results) {
  adjusted_data <- data
  for (i in seq_along(seasonality_results)) {
    if (seasonality_results[i]) {  # Condition check
      ts_data <- ts(data[, i], frequency = frequency)
      decomposed <- stl(ts_data, s.window = "periodic")
      adjusted_data[, i] <- decomposed$time.series[, "remainder"]
    }
  }
  return(adjusted_data)
}

