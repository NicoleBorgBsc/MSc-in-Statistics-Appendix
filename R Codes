# Classical PCA on the original standardised S&P50 dataset
library(dplyr)
library(forecast)
library(tictoc)

pca_result <- prcomp(spricesSP50, center = FALSE, scale. = FALSE)

# Variance explained
var_explained <- (pca_result$sdev)^2
cum_var_explained <- cumsum(var_explained / sum(var_explained))

# Select number of components to reach 90% variance
num_components <- min(which(cum_var_explained >= 0.9))

# Scores and loadings
scores_k <- pca_result$x[, 1:num_components, drop = FALSE]
loadings_k <- pca_result$rotation[, 1:num_components, drop = FALSE]

# Reconstruct standardized data
reconstructed <- scores_k %*% t(loadings_k)

# Compute reconstruction errors
errors <- as.matrix(spricesSP50) - reconstructed
mse <- mean(errors^2)
mae <- mean(abs(errors))
maxae <- max(abs(errors))

