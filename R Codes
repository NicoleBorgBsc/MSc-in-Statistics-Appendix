# Perform PCA
pca_result <- pspricesSP50train, center = FALSE, scale. = FALSE)
# Variance of each principal component
var_explained <- (pca_result$sdev)^2

# Proportion of variance explained
prop_var_explained <- var_explained / sum(var_explained)

# Cumulative variance explained
cum_var_explained <- cumsum(prop_var_explained)

# Print results
prop_var_explained
cum_var_explained
# Number of components to reach 90% cumulative variance
num_components <- min(which(cum_var_explained >= 0.9))
num_components
cum_var_explained[num_components]

# Scree plot
plot(cum_var_explained, type = "b",
     xlab = "Principal Component",
     ylab = "Cumulative Variance Explained",
     main = "Scree Plot")
abline(h = 0.9, col = "red", lty = 2)  # mark 90% variance threshold


# Scores of first k components
scores_k <- pca_result$x[, 1:num_components]

# Loadings of first k components
loadings_k <- pca_result$rotation[, 1:num_components]

# Reconstruct the data (scaled)
reconstructed <- scores_k %*% t(loadings_k)

# Compute MSE between original scaled data and reconstruction
mse <- mean((spricesSP50train - reconstructed)^2)
mse


