#Classical pca

pca_result <- prcomp(stationaryspricesSP50, center = FALSE, scale. = FALSE)

# Variance explained by each component
explained_var <- pca_result$sdev^2 / sum(pca_result$sdev^2)
cumulative_var <- cumsum(explained_var)

# Choose number of components explaining at least 90% of variance
num_components <- which(cumulative_var >= 0.90)[1]
cat("Number of components explaining at least 90% variance:", num_components, "\n")

# Reconstruct the data using the selected components
scores <- pca_result$x[, 1:num_components]
loadings <- pca_result$rotation[, 1:num_components]
reconstructed <- scores %*% t(loadings)  # no centering needed

# Compute error metrics
errors <- stationaryspricesSP50 - reconstructed

mae <- mean(abs(errors))
mse <- mean(errors^2)
maxae <- max(abs(errors))

cat("MAE:", mae, "\n")
cat("MSE:", mse, "\n")
cat("MaxAE:", maxae, "\n")

# Total number of components
total_components <- ncol(stationaryspricesSP50)

# Initialize vectors to store cumulative metrics
mae_cum <- numeric(total_components)
mse_cum <- numeric(total_components)
maxae_cum <- numeric(total_components)

# Loop over 1 to total_components
for (k in 1:total_components) {
  # Reconstruct using first k components
  scores <- pca_result$x[, 1:k]
  loadings <- pca_result$rotation[, 1:k]
  reconstructed <- scores %*% t(loadings)
  
  # Compute errors
  errors <- stationaryspricesSP50 - reconstructed
  
  # Store cumulative metrics
  mae_cum[k] <- mean(abs(errors))
  mse_cum[k] <- mean(errors^2)
  maxae_cum[k] <- max(abs(errors))
}

# Combine results into a data frame
cumulative_errors <- data.frame(
  Components = 1:total_components,
  MAE = mae_cum,
  MSE = mse_cum,
  MaxAE = maxae_cum
)

# View the cumulative metrics
print(cumulative_errors)

